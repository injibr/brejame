{
  "expo": {
    "name": "brejame",
    "slug": "brejame",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.netlonde.brejame"
    },
    "scheme": "brejame",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brejame-logo.png",
        "backgroundColor": "#ffffff",
        "monochromeImage": "./assets/brejame-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.netlonde.brejame",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "brejame"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
